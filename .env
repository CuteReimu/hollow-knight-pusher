# NoneBot2 基础配置
DRIVER=~websockets
SUPERUSERS=[]

# 命令前缀为空字符串，允许直接用指令名触发
COMMAND_START=[""]
COMMAND_SEP=[" "]

# 日志级别
LOG_LEVEL=DEBUG

# QQ 官方机器人凭据，按实际填写
# QQ_IS_SANDBOX=false
# QQ_BOTS=[{"id": "YOUR_APP_ID", "token": "YOUR_BOT_TOKEN", "secret": "YOUR_APP_SECRET", "intent": {"guild_messages": true, "at_messages": true, "c2c_group_at_messages": true}}]
